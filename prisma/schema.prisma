generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      Role     @default(ADMIN)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

enum Role {
  ADMIN
}

enum CvGenerationMethod {
  HEADLESS
  HTML2PDF
}

model Profile {
  id           String   @id @default(cuid())
  fullName     String
  title        String
  titleEn      String?
  titleAr      String?
  email        String
  phone        String
  location     String
  bio          String   @db.Text
  bioEn        String?  @db.Text
  bioAr        String?  @db.Text
  photoUrl          String?
  cvUrl             String?
  cvFileName        String?
  lastCvGeneratedAt DateTime?
  cvTemplateHash    String?
  cvLastSyncedAt    DateTime?
  cvGenerationMode  CvGenerationMethod @default(HEADLESS)
  linkedin          String?
  github       String?
  twitter      String?
  facebook     String?
  instagram    String?
  whatsapp     String?
  updatedAt    DateTime @updatedAt
}

model Experience {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  titleAr     String?
  company     String
  location    String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean  @default(false)
  description String   @db.Text
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  url         String?
  certificateImage String?
  category    String   @default("tech")
  order       Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

enum EducationType {
  DEGREE
  CERTIFICATE
  DIPLOMA
}

model Education {
  id          String       @id @default(cuid())
  degree      String
  degreeEn    String?
  degreeAr    String?
  school      String
  location    String
  startDate   DateTime
  endDate     DateTime?
  current     Boolean      @default(false)
  description String?      @db.Text
  descriptionEn String?    @db.Text
  descriptionAr String?    @db.Text
  url         String?
  certificateImage String?
  type        EducationType @default(DEGREE)
  order       Int          @default(0)
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
}

model Skill {
  id       String @id @default(cuid())
  name     String
  nameEn   String?
  nameAr   String?
  category String
  categoryEn String?
  categoryAr String?
  level    Int    @default(80)
  icon     String?
  order    Int    @default(0)
}

model Project {
  id           String   @id @default(cuid())
  title        String
  titleEn      String?
  titleAr      String?
  description  String   @db.Text
  descriptionEn String? @db.Text
  descriptionAr String? @db.Text
  technologies String[]
  category     String?
  imageUrl     String?
  githubUrl    String?
  demoUrl      String?
  featured     Boolean  @default(false)
  order        Int      @default(0)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Interest {
  id     String @id @default(cuid())
  name   String
  nameEn String?
  nameAr String?
  icon   String?
  order  Int    @default(0)
}

model Testimonial {
  id        String   @id @default(cuid())
  name      String
  role      String
  company   String
  content   String   @db.Text
  imageUrl  String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
}

model Article {
  id          String   @id @default(cuid())
  title       String
  titleEn     String?
  titleAr     String?
  slug        String   @unique
  excerpt     String
  content     String   @db.Text
  imageUrl    String?
  published   Boolean  @default(false)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model Message {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  content   String   @db.Text
  read      Boolean  @default(false)
  reply     String?  @db.Text
  createdAt DateTime @default(now())
}

model Stat {
  id          String   @id @default(cuid())
  type        String
  value       Int      @default(1)
  date        DateTime @default(now())
  ipAddress   String?
  userAgent   String?
}

model HomepageSettings {
  id                  String   @id @default(cuid())

  heroTitle           String?
  heroTitleEn         String?
  heroTitleAr         String?

  heroSubtitle        String?
  heroSubtitleEn      String?
  heroSubtitleAr      String?

  typewriterPhrasesFr String[]
  typewriterPhrasesEn String[]
  typewriterPhrasesAr String[]

  sectionsOrder       String[]
  sectionsVisibility  Json?

  featuredProjectIds  String[]
  visibleStatsTypes   String[]

  updatedAt           DateTime @updatedAt
}

model CvGenerationLog {
  id          String           @id @default(cuid())
  generatedAt DateTime         @default(now())
  method      CvGenerationMethod
  fileSizeKb  Int?
  success     Boolean
  error       String?
}
